# ---- CONFIGURATIONS BASIC ----
DEBUG=TRUE

# ---- CONFIGURATIONS SETTINGS USER
USER_ACTIVATION_EXPIRATION_MINUTES=your_time
RESET_PASSWORD_EXPIRATION_MINUTES=your_time

# ---- CONFIGURATIONS MONGO_DB ----
MONGODB_DB=your_db
MONGODB_HOST=your_host
MONGODB_PORT=your_port default 27017
MONGODB_USERNAME=your_username
MONGODB_PASSWORD=your_password

# ---- CONFIGURATIONS EMAIL ----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email
MAIL_PASSWORD=your_password
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
MAIL_FROM=noreply@your_domain
MAIL_FROM_NAME=your_name

